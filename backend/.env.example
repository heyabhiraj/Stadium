# Copy to .env and fill in to enable real integrations. All are optional;
# unset values fall back to in-process implementations.

# --- Gemini LLM ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Set to 1 to force the deterministic mock even if a key is present.
FORCE_MOCK_LLM=0

# --- Persistence / streaming ---
DATABASE_URL=            # e.g. postgresql+psycopg://user:pass@localhost/stadiummind
REDIS_URL=               # e.g. redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS= # e.g. localhost:9092

# --- External APIs ---
# Google Maps (Directions API, server-side). The browser uses its own
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY in the frontend .env.local.
GOOGLE_MAPS_API_KEY=
# football-data.org free-tier token (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION=WC     # FIFA World Cup competition code
FOOTBALL_DATA_MATCH_ID=          # optional: pin a specific match id
EXTERNAL_TIMEOUT_SECONDS=8

# --- Simulation & thresholds ---
SIMULATION_SEED=42
CONGESTION_THRESHOLD=0.80
QUEUE_ALERT_MINUTES=15

# --- Auth ---
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_TTL_MINUTES=720
