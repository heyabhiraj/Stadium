# Template for frontend production env. Copy to .env.production and fill in.
# DO NOT commit the real .env.production — it is gitignored.
#
# NEXT_PUBLIC_* values are embedded in the browser bundle and are therefore
# PUBLIC by design. A Google Maps *browser* key is not a server secret, but it
# MUST be restricted in the Google Cloud console (HTTP referrer allow-list +
# Maps JS/Directions API restrictions) or it can be abused and billed to you.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-referrer-restricted-maps-key

# Server-side base URL used by the Next.js rewrite proxy.
BACKEND_URL=https://your-backend-host
